[gd_scene load_steps=6 format=3]

; Shapes are built from the EnemyStats resource at _ready, so the placeholders
; here are irrelevant — a bigger enemy is a data change, not a new scene.
;
; Body   : on Enemy, collides with World.
; Hurtbox: on Enemy, watches PlayerAttack.
; Hitbox : on EnemyAttack, watches Player.

[ext_resource type="Script" path="res://src/enemies/enemy.gd" id="1_enemy"]
[ext_resource type="Script" path="res://src/systems/hitbox.gd" id="2_hitbox"]
[ext_resource type="Script" path="res://src/systems/hurtbox.gd" id="3_hurtbox"]
[ext_resource type="Script" path="res://src/systems/body_juice.gd" id="4_juice"]

[sub_resource type="CapsuleShape2D" id="CapsuleShape2D_placeholder"]
radius = 16.0
height = 64.0

[node name="Enemy" type="CharacterBody2D"]
collision_layer = 4
collision_mask = 1
script = ExtResource("1_enemy")

[node name="VisualRoot" type="Node2D" parent="."]
script = ExtResource("4_juice")
rect = NodePath("Visual")

[node name="Visual" type="ColorRect" parent="VisualRoot"]
offset_left = -16.0
offset_top = -64.0
offset_right = 16.0
color = Color(0.75, 0.4, 0.4, 1)

[node name="CollisionShape2D" type="CollisionShape2D" parent="."]
position = Vector2(0, -32)
shape = SubResource("CapsuleShape2D_placeholder")

[node name="Hurtbox" type="Area2D" parent="."]
collision_layer = 4
collision_mask = 8
script = ExtResource("3_hurtbox")

[node name="CollisionShape2D" type="CollisionShape2D" parent="Hurtbox"]
position = Vector2(0, -32)
shape = SubResource("CapsuleShape2D_placeholder")

[node name="Hitbox" type="Area2D" parent="."]
collision_layer = 16
collision_mask = 2
script = ExtResource("2_hitbox")

[node name="CollisionShape2D" type="CollisionShape2D" parent="Hitbox"]
shape = SubResource("CapsuleShape2D_placeholder")
