[gd_scene load_steps=24 format=3]

; Collision layers, per the table in docs/GDD.md and src/systems/collision_layers.gd:
;   1 World  2 Player  3 Enemy  4 PlayerAttack  5 EnemyAttack  6 Pickup
; Body        : on Player, collides with World.
; Hurtbox     : on Player, watches EnemyAttack.
; AttackHitbox: on PlayerAttack, watches Enemy.

[ext_resource type="Script" path="res://src/player/player.gd" id="1_player"]
[ext_resource type="Script" path="res://src/player/states/state_machine.gd" id="2_machine"]
[ext_resource type="Script" path="res://src/player/states/idle.gd" id="3_idle"]
[ext_resource type="Script" path="res://src/player/states/run.gd" id="4_run"]
[ext_resource type="Script" path="res://src/player/states/air.gd" id="5_air"]
[ext_resource type="Script" path="res://src/player/states/roll.gd" id="6_roll"]
[ext_resource type="Script" path="res://src/player/states/attack.gd" id="7_attack"]
[ext_resource type="Script" path="res://src/player/states/parry.gd" id="8_parry"]
[ext_resource type="Script" path="res://src/player/states/hitstun.gd" id="9_hitstun"]
[ext_resource type="Script" path="res://src/player/states/pogo.gd" id="9_pogo"]
[ext_resource type="Script" path="res://src/player/states/hook.gd" id="9_hook"]
[ext_resource type="Script" path="res://src/systems/hitbox.gd" id="10_hitbox"]
[ext_resource type="Script" path="res://src/systems/hurtbox.gd" id="11_hurtbox"]
[ext_resource type="Script" path="res://src/systems/body_juice.gd" id="12_juice"]
[ext_resource type="Script" path="res://src/player/player_sprite.gd" id="13_sprite"]
[ext_resource type="Resource" path="res://src/systems/upgrades/max_health.tres" id="14_hp"]
[ext_resource type="Resource" path="res://src/systems/upgrades/damage.tres" id="15_dmg"]
[ext_resource type="Resource" path="res://src/systems/upgrades/armor.tres" id="16_arm"]
[ext_resource type="Script" path="res://src/player/weapon_sprite.gd" id="17_weapon"]
[ext_resource type="Texture2D" path="res://assets/sprites/weapons.png" id="18_weaponsheet"]

[sub_resource type="CapsuleShape2D" id="CapsuleShape2D_body"]
radius = 14.0
height = 56.0

; The pickaxe tile of the weapon sheet (region + grip per weapons.json) —
; the bare-hands fallback WeaponSprite draws when no WeaponData is equipped.
[sub_resource type="AtlasTexture" id="AtlasTexture_pickaxe"]
atlas = ExtResource("18_weaponsheet")
region = Rect2(0, 0, 24, 24)

[sub_resource type="RectangleShape2D" id="RectangleShape2D_attack"]
size = Vector2(46, 44)

[node name="Player" type="CharacterBody2D"]
collision_layer = 2
collision_mask = 1
script = ExtResource("1_player")
max_health_upgrade = ExtResource("14_hp")
damage_upgrade = ExtResource("15_dmg")
armor_upgrade = ExtResource("16_arm")

; VisualRoot sits between the body and the rect because it is the node that gets
; scaled and spun. Its origin is the player's feet, so a squash flattens
; downward instead of sinking through the floor.
[node name="VisualRoot" type="Node2D" parent="."]
script = ExtResource("12_juice")

; The ColorRect is still BodyJuice's flash target, but it is now invisible — the
; miner sprite sits on top of it. Keeping it means squash/stretch, the roll spin
; and the hit flash all still work through VisualRoot exactly as before, and the
; sprite inherits every one of them for free.
[node name="Visual" type="ColorRect" parent="VisualRoot"]
visible = false
offset_left = -14.0
offset_top = -56.0
offset_right = 14.0
color = Color(0.96, 0.88, 0.72, 1)

; 40x56 sheet at 1x (the Delver redesign) = same 40x56 on screen the old 20x28
; sheet had at 2x, with four times the pixel density. centered=false with an
; offset puts the sprite's feet on the player's origin, which is where the
; collision capsule's feet are.
[node name="Sprite" type="AnimatedSprite2D" parent="VisualRoot" node_paths=PackedStringArray("player")]
position = Vector2(-20, -56)
scale = Vector2(1, 1)
centered = false
texture_filter = 1
script = ExtResource("13_sprite")
player = NodePath("../..")

; Stage-2 weapon layer: the equipped weapon rendered in the glove, driven by
; the manifest's per-frame anchors. After Sprite in tree order so it draws
; over the body. Hidden until a WeaponData carries a sprite (weapons.png is
; authored next in the claude.ai art session).
[node name="WeaponSprite" type="Sprite2D" parent="VisualRoot" node_paths=PackedStringArray("player", "body")]
centered = false
texture_filter = 1
script = ExtResource("17_weapon")
player = NodePath("../..")
body = NodePath("../Sprite")
pickaxe_sprite = SubResource("AtlasTexture_pickaxe")
pickaxe_grip = Vector2(11, 16)

[node name="CollisionShape2D" type="CollisionShape2D" parent="."]
position = Vector2(0, -28)
shape = SubResource("CapsuleShape2D_body")

[node name="Hurtbox" type="Area2D" parent="."]
collision_layer = 2
collision_mask = 16
script = ExtResource("11_hurtbox")

[node name="CollisionShape2D" type="CollisionShape2D" parent="Hurtbox"]
position = Vector2(0, -28)
shape = SubResource("CapsuleShape2D_body")

[node name="AttackHitbox" type="Area2D" parent="."]
position = Vector2(34, -28)
collision_layer = 8
collision_mask = 4
script = ExtResource("10_hitbox")

[node name="CollisionShape2D" type="CollisionShape2D" parent="AttackHitbox"]
shape = SubResource("RectangleShape2D_attack")

; Matches RectangleShape2D_attack (46x44) exactly. What you see is what hits.
[node name="Swing" type="ColorRect" parent="AttackHitbox"]
offset_left = -23.0
offset_top = -22.0
offset_right = 23.0
offset_bottom = 22.0
color = Color(0.85, 0.95, 1, 0.85)

[node name="StateMachine" type="Node" parent="."]
script = ExtResource("2_machine")

[node name="Idle" type="Node" parent="StateMachine"]
script = ExtResource("3_idle")

[node name="Run" type="Node" parent="StateMachine"]
script = ExtResource("4_run")

[node name="Air" type="Node" parent="StateMachine"]
script = ExtResource("5_air")

[node name="Roll" type="Node" parent="StateMachine"]
script = ExtResource("6_roll")

[node name="Attack" type="Node" parent="StateMachine"]
script = ExtResource("7_attack")

[node name="Parry" type="Node" parent="StateMachine"]
script = ExtResource("8_parry")

[node name="Hitstun" type="Node" parent="StateMachine"]
script = ExtResource("9_hitstun")

[node name="Pogo" type="Node" parent="StateMachine"]
script = ExtResource("9_pogo")

[node name="Hook" type="Node" parent="StateMachine"]
script = ExtResource("9_hook")
