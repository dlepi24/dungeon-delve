; The banked readout as a proper HUD card (top-left), matching the delve's:
; ore icon + banked number, with the mine-heat pill appearing beneath only when
; a streak is live. Authored nodes (not an instanced Control), so restating
; layout_mode/anchors is unnecessary — the container sizes to its content.
[node name="BankedCard" type="PanelContainer" parent="HubHud"]
offset_left = 30.0
offset_top = 28.0
mouse_filter = 2
theme_override_styles/panel = SubResource("banked_card")

