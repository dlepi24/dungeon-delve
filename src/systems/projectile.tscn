[gd_scene load_steps=4 format=3]

[ext_resource type="Script" path="res://src/systems/projectile.gd" id="1_proj"]
[ext_resource type="Texture2D" path="res://assets/sprites/rock.png" id="2_rock"]

[sub_resource type="CircleShape2D" id="CircleShape2D_rock"]
radius = 8.0

; Layer 16 = EnemyAttack (hits the player's hurtbox on layer 2).
; Mask 2 | 1: player hurtbox areas, plus World bodies so walls stop it.
; Reflection swaps these to PlayerAttack/Enemy at runtime.
[node name="Projectile" type="Area2D"]
collision_layer = 16
collision_mask = 3
script = ExtResource("1_proj")

[node name="CollisionShape2D" type="CollisionShape2D" parent="."]
shape = SubResource("CircleShape2D_rock")

; rock.png holds two 12x12 variants side by side; projectile.gd picks the
; region deterministically (event/position parity — never randf).
[node name="Rock" type="Sprite2D" parent="."]
texture = ExtResource("2_rock")
texture_filter = 1
region_enabled = true
region_rect = Rect2(0, 0, 12, 12)
