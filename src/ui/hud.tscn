[gd_scene load_steps=3 format=3]

[ext_resource type="Script" path="res://src/ui/hud.gd" id="1_hud"]
[ext_resource type="PackedScene" path="res://src/ui/health_bar.tscn" id="2_bar"]

[node name="Hud" type="CanvasLayer"]
script = ExtResource("1_hud")

; Everything clusters top-left, under where the F3 panel would cover it —
; deliberate: the debug overlay is an occasional tool, the HUD is permanent,
; and stacking them would hide the HUD exactly when you are diagnosing it.
; The health bar is a Node2D, centred on its position, hence x = 40 + 140.
[node name="Bar" parent="." instance=ExtResource("2_bar")]
position = Vector2(180, 40)

[node name="HealthLabel" type="Label" parent="."]
offset_left = 40.0
offset_top = 62.0
offset_right = 320.0
offset_bottom = 88.0
text = "100 / 100"

[node name="Haul" type="Label" parent="."]
offset_left = 40.0
