[gd_resource type="Theme" load_steps=8 format=3]

; The game's one visual voice, applied project-wide (gui/theme/custom in
; project.godot): Rajdhani — condensed, industrial, OFL-licensed — Medium for
; body text, Bold for buttons. Buttons wear the mine's panel language (dark
; warm ground, timber border, amber when live), and the FOCUS ring is bright
; amber on purpose: it is the gamepad's cursor and must never be lost.
; Individual scenes only override SIZES and accent colours, never the family.

[ext_resource type="FontFile" path="res://assets/fonts/Rajdhani-Medium.ttf" id="1_med"]
[ext_resource type="FontFile" path="res://assets/fonts/Rajdhani-Bold.ttf" id="2_bold"]

