[gd_scene load_steps=10 format=3]

; Tuning gym. Every platform here is placed against the DEFAULT jump_height of
; 104 px, with the tallest step at 95 px — deliberately near the limit, so a
; sloppy jump misses and a good one lands. If you tune jump_height, expect the
; spacing to want adjusting with it.
;
; No pits and no death traps: falling always returns you to the floor. This room
; is for judging feel, not for punishing you while you judge it.

[ext_resource type="Script" path="res://src/rooms/gym.gd" id="0_gym"]
[ext_resource type="PackedScene" path="res://src/player/player.tscn" id="1_player"]
[ext_resource type="PackedScene" path="res://src/ui/debug_overlay.tscn" id="2_overlay"]
[ext_resource type="PackedScene" path="res://src/ui/hud.tscn" id="9_hud"]
[ext_resource type="PackedScene" path="res://src/enemies/training_dummy.tscn" id="3_dummy"]
[ext_resource type="Script" path="res://src/systems/screen_shake.gd" id="4_shake"]

[sub_resource type="RectangleShape2D" id="RectangleShape2D_floor"]
size = Vector2(1840, 80)

[sub_resource type="RectangleShape2D" id="RectangleShape2D_wall"]
size = Vector2(40, 1080)

[sub_resource type="RectangleShape2D" id="RectangleShape2D_platform"]
size = Vector2(240, 30)

; The low step is a solid block down to the floor. As a floating slab its
; underside sat 50 px up — too low to walk or roll beneath, so it read as a
; passage and played as a wall you could only jump over.
[sub_resource type="RectangleShape2D" id="RectangleShape2D_step"]
size = Vector2(240, 80)

[node name="Gym" type="Node2D"]
script = ExtResource("0_gym")

; Static, centred on the room, which is exactly viewport-sized — so the framing
; is identical to having no camera at all until something shakes it. Deliberately
; does not follow the player: camera lag would muddy the very feel being judged.
; A real follow camera is M4's problem, once rooms are bigger than the screen.
[node name="Camera2D" type="Camera2D" parent="."]
position = Vector2(960, 540)
script = ExtResource("4_shake")

