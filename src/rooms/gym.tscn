dummy = NodePath("../TrainingDummy")

; Dev affordance, not product UI — M7 owns real menus and controller glyphs.
; It exists because a build that does not tell you its verbs gets judged on the
; verbs you happened to guess.
[node name="ControlsHint" type="CanvasLayer" parent="."]

