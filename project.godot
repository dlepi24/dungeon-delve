[layer_names]

2d_physics/layer_1="World"
2d_physics/layer_2="Player"
2d_physics/layer_3="Enemy"
2d_physics/layer_4="PlayerAttack"
2d_physics/layer_5="EnemyAttack"
2d_physics/layer_6="Pickup"

[physics]

; Pinned per the GDD (determinism). Equals the engine default so Godot drops it
; on any re-save; stripped SEVEN times now. tools/check.tscn fails if the tick is
; ever actually wrong.
common/physics_ticks_per_second=60

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
